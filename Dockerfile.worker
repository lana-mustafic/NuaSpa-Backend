# NuaSpa.Worker — pomoćni mikroservis (RabbitMQ consumer)
FROM mcr.microsoft.com/dotnet/sdk:9.0.203-bookworm-slim AS build
WORKDIR /src
COPY . .
RUN dotnet restore "NuaSpa.slnx"
WORKDIR /src/src/NuaSpa.Worker
RUN dotnet publish "NuaSpa.Worker.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/runtime:9.0.3-bookworm-slim AS final
WORKDIR /app
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "NuaSpa.Worker.dll"]
