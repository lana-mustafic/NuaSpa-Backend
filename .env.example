# Kopiraj u .env i prilagodi vrijednosti (datoteka .env se ne commita).
# Jedini izvor konfiguracije za API i Worker — ne hardkodirati u appsettings.json.

# --- SQL Server ---
ConnectionStrings__DefaultConnection=Server=(localdb)\mssqllocaldb;Database=210240;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;
MSSQL_SA_PASSWORD=YourStrongPassword123!

# --- API host ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5088
UseHttpsRedirection=true

# --- JWT ---
JwtSettings__Key=NuaSpa-Development-Only-Signing-Key-AtLeast-32-Chars-Not-For-Production
JwtSettings__Issuer=NuaSpaBackend
JwtSettings__Audience=NuaSpaClients
JwtSettings__DurationInMinutes=60

# --- Stripe ---
Stripe__SecretKey=
Stripe__PublishableKey=
Stripe__WebhookSecret=
Stripe__Currency=bam

# --- RabbitMQ ---
RabbitMQ__Host=localhost
RabbitMQ__Port=5672
RabbitMQ__UserName=guest
RabbitMQ__Password=guest
RabbitMQ__NotificationsQueue=nuaspa_notifications

# --- E-mail (API obavijesti + Worker slanje) ---
Email__AdminNotify=admin@nuaspa.ba
Email__FromAddress=noreply@nuaspa.ba
Email__FromName=NuaSpa
Email__OutboxDirectory=email-outbox
TherapistInvite__BaseUrl=nuaspa://accept-invite

# --- CORS (browser clients: Flutter web, admin SPA) ---
# Override defaults with indexed env vars. Match the exact origin (scheme + host + port).
# Cors__AllowedOrigins__0=http://localhost:8080
# Cors__AllowedOrigins__1=http://127.0.0.1:8080
# Cors__AllowedOrigins__2=http://localhost:50000
# Cors__AllowedOrigins__3=https://app.nuaspa.ba

# --- SMTP (Worker) ---
Smtp__Enabled=false
Smtp__Host=localhost
Smtp__Port=587
Smtp__UseSsl=true
Smtp__UserName=
Smtp__Password=

# --- Docker Compose (prepisuje gornje za kontejnere) ---
# ConnectionStrings__DefaultConnection=Server=nuaspa-db;Database=210240;User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=True;MultipleActiveResultSets=true
# RabbitMQ__Host=rabbitmq
# ASPNETCORE_ENVIRONMENT=Docker
# DOTNET_ENVIRONMENT=Docker
# UseHttpsRedirection=false
